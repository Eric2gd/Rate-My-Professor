// repository pattern abstracting all database operations
class ReplyRepository {
  constructor(db) {
    this.db = db;
  }

  getByReview(review_id) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "SELECT * FROM replies WHERE review_id = ? ORDER BY created_at ASC",
        [review_id],
        (err, results) => {
          if (err) reject(err);
          else resolve(results);
        }
      );
    });
  }

  react(replyId, username, value) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "SELECT value FROM reply_likes WHERE reply_id = ? AND username = ?",
        [replyId, username],
        (err, rows) => {
          if (err) return reject(err);
          const existing = rows[0];
          const isSame = existing && existing.value === value;
          const sql = isSame
            ? "DELETE FROM reply_likes WHERE reply_id = ? AND username = ?"
            : `INSERT INTO reply_likes (reply_id, username, value) VALUES (?, ?, ?)
               ON DUPLICATE KEY UPDATE value = VALUES(value)`;
          const params = isSame ? [replyId, username] : [replyId, username, value];
          this.db.query(sql, params, (err2) => {
            if (err2) return reject(err2);
            this.db.query(
              `SELECT
                 COALESCE(SUM(value = 1), 0)  AS likes,
                 COALESCE(SUM(value = -1), 0) AS dislikes,
                 (SELECT value FROM reply_likes WHERE reply_id = ? AND username = ?) AS my_vote
               FROM reply_likes WHERE reply_id = ?`,
              [replyId, username, replyId],
              (err3, result) => {
                if (err3) reject(err3);
                else resolve(result[0]);
              }
            );
          });
        }
      );
    });
  }

  update(id, username, reply_text) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "UPDATE replies SET reply_text = ? WHERE id = ? AND username = ?",
        [reply_text, id, username],
        (err, result) => {
          if (err) reject(err);
          else if (result.affectedRows === 0) reject(new Error("Not found or not yours"));
          else resolve({ id, reply_text });
        }
      );
    });
  }

  delete(id, username) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "DELETE FROM replies WHERE id = ? AND username = ?",
        [id, username],
        (err, result) => {
          if (err) reject(err);
          else if (result.affectedRows === 0) reject(new Error("Not found or not yours"));
          else resolve();
        }
      );
    });
  }

  create(data) {
    const { review_id, username, reply_text } = data;

    return new Promise((resolve, reject) => {
      this.db.query(
        "INSERT INTO replies (review_id, username, reply_text) VALUES (?, ?, ?)",
        [review_id, username, reply_text],
        (err, result) => {
          if (err) reject(err);
          else resolve({ id: result.insertId, ...data });
        }
      );
    });
  }
}

module.exports = ReplyRepository;