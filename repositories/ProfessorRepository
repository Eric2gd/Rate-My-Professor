// repository pattern abstracting all database operations
class ProfessorRepository {
  constructor(db) {
    this.db = db;
  }

  getAll() {
    return new Promise((resolve, reject) => {
      this.db.query(
        `SELECT p.*, d.name AS department
         FROM professors p
         LEFT JOIN departments d ON p.department_id = d.id
         ORDER BY p.name ASC`,
        (err, results) => {
          if (err) reject(err);
          else resolve(results);
        }
      );
    });
  }

  create(name, department) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "INSERT INTO professors (name, department) VALUES (?, ?)",
        [name, department],
        (err, result) => {
          if (err) reject(err);
          else resolve({ id: result.insertId, name, department });
        }
      );
    });
  }
}

module.exports = ProfessorRepository;