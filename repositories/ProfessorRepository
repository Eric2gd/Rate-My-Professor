// repository pattern abstracting all database operations
class ProfessorRepository {
  constructor(db) {
    this.db = db;
  }

  getAll() {
    return new Promise((resolve, reject) => {
      this.db.query("SELECT * FROM professors", (err, results) => {
        if (err) reject(err);
        else resolve(results);
      });
    });
  }

  create(name, department) {
    return new Promise((resolve, reject) => {
      this.db.query(
        "INSERT INTO professors (name, department) VALUES (?, ?)",
        [name, department],
        (err, result) => {
          if (err) reject(err);
          else resolve({ id: result.insertId, name, department });
        }
      );
    });
  }
}

module.exports = ProfessorRepository;